# QuickBooks OAuth 2.0
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/callback
QBO_ENVIRONMENT=sandbox

# Encryption
TOKEN_ENCRYPTION_KEY=  # 32-byte hex string for AES-256

# External Audit Log (optional, recommended for production)
AUDIT_S3_BUCKET=
AUDIT_S3_REGION=

# KMS (optional, recommended for production)
KMS_PROVIDER=  # aws | azure | vault
KMS_KEY_ID=

# Webhook Receiver (optional)
WEBHOOK_PORT=3001
WEBHOOK_VERIFIER_TOKEN=

# Redis (for BullMQ webhook queue, optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
